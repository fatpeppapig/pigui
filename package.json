{
    "name": "pigui",
    "version": "0.0.4",
    "description": "PigUI — Svelte 5 components themed entirely by Tailwind CSS V4 semantic tokens",
    "license": "0BSD",
    "type": "module",
    "svelte": "./src/lib/index.ts",
    "types": "./src/lib/index.ts",
    "exports": {
        ".": {
            "types": "./src/lib/index.ts",
            "svelte": "./src/lib/index.ts",
            "default": "./src/lib/index.ts"
        },
        "./theme.css": "./src/styles/theme.css",
        "./package.json": "./package.json"
    },
    "scripts": {
        "test": "vitest run",
        "check": "svelte-check --tsconfig ./tsconfig.json",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "showcase:dev": "vite dev --config vite.config.showcase.ts",
        "showcase:build": "vite build --config vite.config.showcase.ts",
        "showcase:preview": "vite preview --config vite.config.showcase.ts",
        "showcase:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.showcase.json",
        "format": "prettier --write .",
        "format-check": "prettier --check ."
    },
    "peerDependencies": {
        "svelte": "^5.0.0"
    },
    "devDependencies": {
        "@storybook/addon-docs": "^10.5.0",
        "@storybook/addon-svelte-csf": "^5.1.2",
        "@storybook/svelte-vite": "^10.5.0",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.22.0",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/vite": "^4.3.2",
        "@testing-library/svelte": "^5.4.2",
        "jsdom": "^29.1.1",
        "prettier": "^3.9.5",
        "prettier-plugin-svelte": "^4.1.1",
        "storybook": "^10.5.0",
        "svelte": "^5.56.4",
        "svelte-check": "^4.7.1",
        "tailwindcss": "^4.3.2",
        "typescript": "^6.0.3",
        "vite": "^7.3.6",
        "vitest": "^4.1.10"
    },
    "dependencies": {
        "@tabler/icons-svelte": "^3.44.0"
    }
}
